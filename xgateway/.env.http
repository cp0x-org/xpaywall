PORT=8081
LOG_LEVEL=INFO

# --- File provider mode (default) ---
# CONFIG_PROVIDER=file
#CONFIG_FILE=config.example.yaml

# --- HTTP provider mode (fetches all config from control-api per request) ---
CONFIG_PROVIDER=http
CONTROL_API_URL=http://localhost:9091
INTERNAL_API_KEY=change-me-internal-secret-key

GIN_MODE=debug # debug | test | release
DEBUG=true
